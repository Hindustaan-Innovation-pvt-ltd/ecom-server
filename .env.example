NODE_ENV="development"
PORT=8080

# Database
MONGODB_URI="mongodb://127.0.0.1:27017/hmarketplace"

# Authentication
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"
SESSION_SECRET="your-cookie-session-secret"
COOKIE_SECURE="false"

# Password Utility AES Encryption Key
ENCRYPTION_KEY="your-stable-encryption-key-for-passwords"

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Redis Cache configuration
REDIS_URL="redis://127.0.0.1:6379"

# Nodemailer SMTP configuration (Optional in Dev - automatically falls back to Ethereal/Console)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_pass"
EMAIL_FROM="HMarketplace Support <noreply@hmarketplace.com>"

# Firebase Configuration
FIREBASE_API_KEY="your-firebase-web-api-key"
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_AUTH_DOMAIN="your-firebase-auth-domain"
FIREBASE_STORAGE_BUCKET="your-firebase-storage-bucket"
FIREBASE_MESSAGING_SENDER_ID="your-firebase-messaging-sender-id"
FIREBASE_APP_ID="your-firebase-app-id"
FIREBASE_MEASUREMENT_ID="your-firebase-measurement-id"

# Firebase Admin SDK Credentials (Optional - fallbacks to REST API verifyIdToken)
FIREBASE_CLIENT_EMAIL="your-firebase-client-email"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
