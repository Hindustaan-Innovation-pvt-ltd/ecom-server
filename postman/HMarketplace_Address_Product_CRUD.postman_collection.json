{
  "info": {
    "_postman_id": "a576dbff-d7d8-4f8e-bd3a-59b8eb25c7e1",
    "name": "HMarketplace - Address & Product Catalog CRUD",
    "description": "Comprehensive Postman Collection for testing HMarketplace's Indian Address validation system and complete Product Catalog (Categories, Products, Images, and Variants) CRUD operations, supporting stateful Passport session-auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Address Module (/api/address)",
      "description": "Endpoints for managing Indian shipping addresses with strict pincode, landmark, state, and mobile validations.",
      "item": [
        {
          "name": "Add Indian Shipping Address",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.address) {",
                  "    pm.collectionVariables.set(\"lastAddressId\", jsonData.address._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Rajesh Kumar\",\n  \"phone\": \"+919876543210\",\n  \"line1\": \"Flat 202, Block C, Silver Oak Apartments\",\n  \"line2\": \"100 Feet Road, Indiranagar\",\n  \"landmark\": \"Near Indiranagar Metro Station\",\n  \"city\": \"Bengaluru\",\n  \"state\": \"Karnataka\",\n  \"pincode\": \"560038\",\n  \"isDefault\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/address",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "address"
              ]
            },
            "description": "Creates a shipping address. Validates Indian pincode formats (6 digits starting with 1-9), Indian mobile formats (starts with 6-9), landmarks, and legal states enum. Triggers automatic default toggles."
          },
          "response": []
        },
        {
          "name": "List Own Addresses",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/address",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "address"
              ]
            },
            "description": "Lists all addresses of the authenticated caller. Defaults are sorted first in the list."
          },
          "response": []
        },
        {
          "name": "Read Specific Address",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/address/{{lastAddressId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "address",
                "{{lastAddressId}}"
              ]
            },
            "description": "Reads a specific address by its database identifier. Requires ownership or Admin privileges."
          },
          "response": []
        },
        {
          "name": "Update Own Address",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Rajesh Kumar Updated\",\n  \"phone\": \"09876543210\",\n  \"line1\": \"Flat 202-A, Block C, Silver Oak Apartments\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/address/{{lastAddressId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "address",
                "{{lastAddressId}}"
              ]
            },
            "description": "Updates specific fields on a shipping address owned by the caller."
          },
          "response": []
        },
        {
          "name": "Delete Own Address",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/address/{{lastAddressId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "address",
                "{{lastAddressId}}"
              ]
            },
            "description": "Deletes the target address. If the deleted item was a default address, the system automatically promotes another address to default."
          },
          "response": []
        }
      ]
