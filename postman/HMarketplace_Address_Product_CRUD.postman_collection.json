        {
          "name": "Upload Product Images (Seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.images && jsonData.images.length > 0) {",
                  "    pm.collectionVariables.set(\"lastImageId\", jsonData.images[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "description": "Array of files (up to 10)",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/product/{{lastProductId}}/images",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "product",
                "{{lastProductId}}",
                "images"
              ]
            },
            "description": "Upload multiple catalog photographs via Multer array routing through Cloudinary."
          },
          "response": []
        },
