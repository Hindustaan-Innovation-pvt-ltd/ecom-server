    {
      "name": "2. Product Catalog Module (/api/product)",
      "description": "Endpoints to manage Categories, Product Catalog postings, image uploads, and Product variants.",
      "item": [
        {
          "name": "Create Category (Admin Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.category) {",
                  "    pm.collectionVariables.set(\"lastCategoryId\", jsonData.category._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Smartphones & Accessories\",\n  \"imageUrl\": \"https://res.cloudinary.com/demo/image/upload/v1234/smartphones.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/product/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "product",
                "categories"
              ]
            },
            "description": "Registers a new product category. Enforces Admin role validation."
          },
          "response": []
        },
        {
          "name": "Create Sub-Category (Admin Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mobile Screen Protectors\",\n  \"imageUrl\": \"https://res.cloudinary.com/demo/image/upload/v1234/protectors.jpg\",\n  \"parentId\": \"{{lastCategoryId}}\",\n  \"sortOrder\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/product/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "product",
                "categories"
              ]
            },
            "description": "Registers a new hierarchical sub-category under a parent category. Enforces Admin role validation."
          },
          "response": []
        },
        {
          "name": "Get All Categories (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/product/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "product",
                "categories"
              ]
            },
            "description": "Lists all active categories in alphabetical order."
          },
          "response": []
        },
        {
          "name": "Create Product (Seller Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.product) {",
                  "    pm.collectionVariables.set(\"lastProductId\", jsonData.product._id);",
                  "    pm.collectionVariables.set(\"productSlug\", jsonData.product.slug);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{lastCategoryId}}\",\n  \"title\": \"OnePlus 12 5G Silky Black\",\n  \"description\": \"Flagship phone featuring Snapdragon 8 Gen 3 and Hasselblad Camera.\",\n  \"brand\": \"OnePlus\",\n  \"sku\": \"1PL-OP12-256G-BLK\",\n  \"pricePaise\": 6499900,\n  \"comparePricePaise\": 6999900,\n  \"inventory\": 100,\n  \"tags\": [\"flagship\", \"oneplus\", \"5g\", \"android\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/product",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "product"
              ]
            },
            "description": "Post a new approved product posting. Prices are stored in Paise (integers) to prevent float issues. Role restricted to registered Sellers."
          },
          "response": []
        },
        {
          "name": "Query Products List (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/product?brand=OnePlus&minPrice=100000&maxPrice=10000000&sort=priceAsc&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "product"
              ],
              "query": [
                {
                  "key": "categoryId",
                  "value": "{{lastCategoryId}}",
                  "disabled": true
                },
                {
                  "key": "brand",
                  "value": "OnePlus"
                },
                {
                  "key": "minPrice",
                  "value": "100000",
                  "description": "Price in Paise"
                },
                {
                  "key": "maxPrice",
                  "value": "10000000",
                  "description": "Price in Paise"
                },
                {
                  "key": "search",
                  "value": "Hasselblad",
                  "disabled": true
                },
                {
                  "key": "sort",
                  "value": "priceAsc"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Advanced catalog search with pagination, multi-field regex searches, and price boundaries (in Paise)."
          },
          "response": []
        },
